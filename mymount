#!/bin/bash
set -euo pipefail

# ===========================
# 1. Root and tool checks
# ===========================
if [[ "$(id -u)" -ne 0 ]]; then
  echo "ERROR: This must be run as root (sudo)."
  exit 1
fi

if ! command -v mount.nfs >/dev/null 2>&1; then
  echo "ERROR: mount.nfs not found. Install nfs-common or equivalent."
  exit 1
fi

# ===========================
# 2. Discover shares from env
# ===========================
# Find MYMOUNT_NAS_<name> in environment, collect share names
share_names=()
while IFS='=' read -r var _; do
  [[ "$var" =~ ^MYMOUNT_NAS_([A-Za-z0-9_]+)$ ]] || continue
  share="${BASH_REMATCH[1]}"
  share_names+=("$share")
done < <(env)

if [[ ${#share_names[@]} -eq 0 ]]; then
  echo "ERROR: No NAS shares configured in environment. Export variables like MYMOUNT_NAS_backups."
  exit 1
fi

# ===========================
# 3. Build NAS/Local path maps
# ===========================
declare -A NAS_PATHS
declare -A LOCAL_PATHS

local_root="${MYMOUNT_LOCAL_ROOT:-$HOME/lanshares}"

for share in "${share_names[@]}"; do
  nas_var="MYMOUNT_NAS_${share}"
  NAS_PATHS["$share"]="${!nas_var}"

  local_var="MYMOUNT_LOCAL_${share}"
  # Default: $local_root/share
  LOCAL_PATHS["$share"]="${!local_var:-$local_root/$share}"
done

# ===========================
# 4. Help function
# ===========================
help() {
  echo "**USAGE**"
  echo "$(basename "$0") [options]"
  echo
  echo "Options:"
  for share in "${share_names[@]}"; do
    echo "  -${share:0:1}, --$share   Mount/unmount '$share' share"
  done
  echo "  -a, --all       All shares listed above"
  echo "  -h, --help      This help message"
  echo
  echo "Environment-based shares discovered:"
  for share in "${share_names[@]}"; do
    echo "  $share: NAS='${NAS_PATHS[$share]}', LOCAL='${LOCAL_PATHS[$share]}'"
  done
  echo
  echo "You may define new shares by setting MYMOUNT_NAS_<name> and optionally MYMOUNT_LOCAL_<name>."
  exit 1
}

# ===========================
# 5. Argument parsing
# ===========================
[[ $# -eq 0 ]] && help

# Build actions list
shares=()
while [[ $# -gt 0 ]]; do
  opt="$1"
  found=0
  case "$opt" in
    -a|--all)
      shares=("${share_names[@]}")
      found=1
      ;;
    -h|--help)
      help
      ;;
    *)
      for share in "${share_names[@]}"; do
        if [[ "$opt" == "-${share:0:1}" || "$opt" == "--$share" ]]; then
          shares+=("$share")
          found=1
          break
        fi
      done
      ;;
  esac
  if [[ $found -eq 0 ]]; then
    echo "Invalid option: $opt"
    help
  fi
  shift
done

# Deduplicate shares
mapfile -t shares < <(printf "%s\n" "${shares[@]}" | sort -u)

if [[ ${#shares[@]} -eq 0 ]]; then
  echo "No valid shares requested."
  help
fi

# ===========================
# 6. Action determination
# ===========================
mycommand="$(basename "$0")"
action=""
if [[ "$mycommand" == "mymount" ]]; then
  action="mount"
elif [[ "$mycommand" == "myunmount" ]]; then
  action="unmount"
else
  echo "Unknown command name: $mycommand"
  exit 1
fi

nfsopts="${MYMOUNT_OPTS:-tcp,vers=3}"

# ===========================
# 7. Main loop (continue on errors)
# ===========================
failures=()
for share in "${shares[@]}"; do
  naspath="${NAS_PATHS[$share]}"
  localpath="${LOCAL_PATHS[$share]}"

  if [[ "$action" == "mount" ]]; then
    mkdir -p "$localpath"
    if mountpoint -q "$localpath"; then
      echo "$localpath: already mounted."
    else
      echo "Mounting '$share' to $localpath..."
      if ! mount -o "$nfsopts" -t nfs "$naspath" "$localpath"; then
        echo "FAILED to mount $share."
        failures+=("$share")
      fi
    fi
  elif [[ "$action" == "unmount" ]]; then
    if mountpoint -q "$localpath"; then
      echo "Unmounting '$share' from $localpath..."
      if ! umount "$localpath"; then
        echo "FAILED to unmount $localpath."
        failures+=("$share")
      fi
    else
      echo "$localpath: not mounted."
    fi
  fi
done

if [[ ${#failures[@]} -gt 0 ]]; then
  echo "The following shares FAILED: ${failures[*]}"
  exit 1
fi

