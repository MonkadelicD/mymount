# ========================================
# mymount Environment Configuration
# ========================================
# Copy this file to ~/.config/mymount/env and edit for your NAS.
# The script auto-loads from $XDG_CONFIG_HOME/mymount/env.
# Falls back to the original user's config when run under sudo.
#
# Usage: sudo mymount --all
# ========================================

# --- NAS Root (server:base_path) ---
export MYMOUNT_NAS_ROOT="nas.internal:/storage"

# --- Share Definitions ---
# Format: export MYMOUNT_NAS_<name>="${MYMOUNT_NAS_ROOT}/<path>"
export MYMOUNT_NAS_data="${MYMOUNT_NAS_ROOT}/data"
# export MYMOUNT_NAS_backups="${MYMOUNT_NAS_ROOT}/backups"
# export MYMOUNT_NAS_media="${MYMOUNT_NAS_ROOT}/media"

# --- Local Mount Root (default: $HOME/lanshares) ---
export MYMOUNT_LOCAL_ROOT="$HOME/lanshares"

# --- Optional: Override individual local mount points ---
# export MYMOUNT_LOCAL_data="/mnt/data"
# export MYMOUNT_LOCAL_backups="$MYMOUNT_LOCAL_ROOT/backups"

# --- Optional: NFS mount options (default: tcp,vers=3) ---
export MYMOUNT_OPTS="tcp,vers=4,hard"
